<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>LeafNote - The ultimate blogging app</title>
  </head>

  <body>
    <%- include('./partials/navbar') %>

    <div class="container mt-4">
      <div class="text-center">
        <h1><%= blog.title %></h1>
        <img
          src="<%= blog.cover_image_url %>"
          class="img-fluid mt-4"
          width="700px"
          alt="..."
        />
      </div>

      <div class="container mt-4 border-top border-bottom py-3">
        <div class="d-flex justify-content-end align-items-center gap-3">
          <img
            src="<%= blog.author.profile_image_url %>"
            alt="Author avatar"
            class="rounded-circle"
            style="width: 50px; height: 50px; object-fit: cover"
          />
          <span class="fw-semibold"><%= blog.author.full_name %></span>
        </div>
      </div>

      <pre class="mt-4">
            <%= blog.body %>
        </pre
      >
    </div>

    <!-- Comments Section -->
    <div class="container mt-5 mb-5">
      <h3>Comments (<%= locals.comments.length || 0 %>)</h3>

      <% if (locals.user) { %>
      <!-- Comment Form -->
      <form action="/blog/comment/<%= blog._id %>" method="post" class="mb-4">
        <div class="mb-3">
          <label for="content" class="form-label">Leave a comment:</label>
          <textarea
            class="form-control"
            name="content"
            id="exampleFormControlTextarea1"
            rows="3"
          ></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Post Comment</button>
      </form>
      <% } %>

      <!-- List of Comments -->
      <% if (locals.comments && locals.comments.length > 0) { %>
      <ul class="list-group">
        <% locals.comments.forEach(comment => { %>
        <li class="list-group-item rounded-2">
          <div class="d-flex align-items-start gap-2">
            <img
              src="<%= comment.author.profile_image_url %>"
              alt="Author avatar"
              class="rounded-circle"
              style="width: 50px; height: 50px; object-fit: cover"
            />
            <div>
                <strong><%= comment.author.full_name || "Anonymous" %>:</strong>
                <pre class="mb-0"><%= comment.content %></pre>
            </div>
          </div>
        </li>
        <% }) %>
      </ul>
      <% } else { %>
      <p class="text-muted">No comments yet. Be the first to comment!</p>
      <% } %>
    </div>

    <%- include('./partials/scripts.ejs') %>
  </body>
</html>
